{
  "name": "cheesekit",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "pnpm --filter @cheesekit/tool-sdk --filter @cheesekit/llm-gateway --filter @cheesekit/chzzk-adapter --filter @cheesekit/core --filter @cheesekit/storage --filter @cheesekit/manzai-bot build && pnpm --filter @cheesekit/desktop dev",
    "build": "pnpm -r --sort run build",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "lint": "node -e \"console.log('No lint configuration yet.')\""
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.2.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vitest": "^3.1.2",
    "wait-on": "^8.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"]
  }
}
